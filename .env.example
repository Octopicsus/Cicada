# ---------------------------------------------------------------------------
# Cicada — example environment.
#
# Copy to `.env.local` (already gitignored) and fill in. NEVER commit real
# secrets. Production secrets live in Vercel / Supabase project settings, not
# in this repo.
# ---------------------------------------------------------------------------

# --- Supabase --------------------------------------------------------------
# Public URL + anon key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Server-only. Has full access — never expose to the browser, never bake into
# Next.js pages, never log.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Direct Postgres connection. Used by Supabase CLI (`supabase db push`,
# migration generation) and by domain-level scripts.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- GoCardless / Banking --------------------------------------------------
# Bank Account Data sandbox credentials from the Octomize merchant account.
# Live with the 50 active connections / month cap until a paid contract is
# signed (see Cicada vault note "Update 2026-04-28: GoCardless support response").
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# --- Currency rates --------------------------------------------------------
# ECB FX rates via frankfurter.app — free, no auth.
ECB_RATES_BASE_URL=https://api.frankfurter.app

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=

# --- Observability ---------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- Rate limiting (Upstash Redis) -----------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Misc ------------------------------------------------------------------
# Default base currency at onboarding when we can't infer from locale.
NEXT_PUBLIC_DEFAULT_BASE_CURRENCY=EUR

# ---- Salt Edge (sandbox banking provider) -----------------------------
# Setup log: vault → "Cicada - Salt Edge Setup"
# Credentials живут только в .env.local — НЕ коммитить
SALT_EDGE_APP_ID=
SALT_EDGE_SECRET=
SALT_EDGE_BASE_URL=https://www.saltedge.com/api/v6

# ---- Monobank (direct banking provider, UA users) ---------------------
# Personal API token from https://api.monobank.ua/. Per-token rate limit
# is 1 request / 60 seconds — handled by the sync orchestration layer.
# Used by smoke test:
#   pnpm exec tsx packages/domain/src/banking/providers/monobank/__smoke__/validate.ts
MONOBANK_TOKEN=
